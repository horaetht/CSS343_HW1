{
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: build project",
            "command": "/usr/bin/g++",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "-Iinclude",
                "main.cpp",
                "src/*.cpp",
                "-o",
                "build/myProgram"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "Build entire C++ project"
        }
    ],
    "version": "2.0.0"
}
